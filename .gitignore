# LeafPan 项目 .gitignore 文件
# 此文件包含了 Java、Vue.js、Maven、Node.js 以及开发环境的忽略规则

###############################################################################
# 操作系统生成的文件
###############################################################################
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

###############################################################################
# 构建输出
###############################################################################
# Java 构建输出
target/
!**/src/main/**/target/
!**/src/test/**/target/

# Vue.js 构建输出
dist/
build/

# 通用构建文件
*.jar
*.war
*.ear
*.zip
*.tar.gz
*.rar
*.cab
*.msi
*.msm
*.msp

###############################################################################
# 依赖目录
###############################################################################
# Node.js
node_modules/

# Maven
.mvn/

# Gradle
.gradle/

# Java 依赖
jspm_packages/

###############################################################################
# IDE/编辑器
###############################################################################
# VS Code
.vscode/
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json
*.vscode/*

# IntelliJ IDEA
.idea/
*.iws
*.iml
*.ipr
out/

# Eclipse
.metadata/
bin/
tmp/
*.tmp
*.bak
*.swp
*~.nib
local.properties
.settings/
.loadpath
.recommenders

# STS
.apt_generated
.classpath
.factorypath
.project
.springBeans
.sts4-cache

# NetBeans
/nbproject/private/
/nbbuild/
/nbdist/
/.nb-gradle/
!**/src/main/**/build/
!**/src/test/**/build/

# 其他编辑器
*.suo
*.ntvs*
*.njsproj
*.sln
*.sln.DotSettings.user
*.sw?
*.sublime-project
*.sublime-workspace
.projectile

###############################################################################
# 日志文件
###############################################################################
logs/
*.log
*.log.*
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
hs_err_pid*

###############################################################################
# 环境变量和配置
###############################################################################
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env.test
.env*

# 本地开发配置
local-config/
config/local*

###############################################################################
# 测试和覆盖率
###############################################################################
# 测试覆盖
coverage/
*.lcov
.nyc_output

# 测试运行时数据
pids/
*.pid
*.seed
*.pid.lock

###############################################################################
# Node.js 相关
###############################################################################
# 包管理器锁文件
package-lock.json
yarn.lock
pnpm-lock.yaml

# npm 缓存
.npm

# eslint 缓存
.eslintcache

# Microbundle 缓存
.rpt2_cache/
.rts2_cache_cjs/
.rts2_cache_es/
.rts2_cache_umd/

# REPL 历史
.node_repl_history

# npm pack 输出
*.tgz

# Yarn 完整性文件
.yarn-integrity

# Parcel 缓存
.cache
.parcel-cache

# Next.js 构建输出
.next

# Nuxt.js 构建输出
.nuxt

# VuePress 构建输出
.vuepress/dist

# Serverless
.serverless/

# FuseBox 缓存
.fusebox/

# DynamoDB Local
.dynamodb/

# TernJS 端口文件
.tern-port

# VSCode 测试
.vscode-test

###############################################################################
# 容器和部署
###############################################################################
# Docker
.docker/

# Kubernetes 敏感配置
k8s/*-secret.yaml
k8s/*-secret.yml

###############################################################################
# 项目特定
###############################################################################
# 数据库备份
*.sql
*.dump
backup/

# 临时文件夹
tmp/
temp/
.cache/

# Mobile Tools for Java
.mtj.tmp/

# 虚拟机崩溃日志
hs_err_pid*
